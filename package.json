{
  "name": "apex-flutter",
  "version": "2.0.6",
  "scripts": {
    "dev": "flutter run --flavor dev -t lib/main_dev.dart",
    "dev:release": "flutter run --flavor dev -t lib/main_dev.dart --release",
    "prod": "flutter run --flavor prod -t lib/main.dart",
    "prod:release": "flutter run --flavor prod -t lib/main.dart --release",
    "build:apk:dev": "flutter build apk --flavor dev -t lib/main_dev.dart",
    "build:apk:prod": "flutter build apk --flavor prod -t lib/main.dart",
    "build:appbundle:prod": "flutter build appbundle --flavor prod -t lib/main.dart",
    "clean": "flutter clean && flutter pub get",
    "test": "flutter test",
    "analyze": "flutter analyze",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0"
  }
}
